# Copy this file to `.env` and adjust values for your local dev environment.
# `.env` is gitignored by default.

# Node environment: development | test | production
NODE_ENV=development

# Server bind address and port
HOST=127.0.0.1
PORT=3000

# Where the server keeps the live DB, shared version archives, and local caches.
# Defaults to the OS temp directory if not set.
STORAGE_ROOT=./tmp/dev-storage

# Optional: override the live DB path (mostly used by tests).
# DATABASE_URL=./tmp/dev-storage/app.sqlite

# Optional: root directory exposed by the shared-folder import browser.
# SHARED_FOLDER_ROOT=./tmp/dev-storage

# Pre-built web assets directory. In production this is bundled next to main.js.
APP_WEB_ROOT=./apps/web/dist

# Builtin fallback plugin directory.
BUILTIN_PATH=./packages/plugin-file/dist

# Comma-separated dev plugin directories (absolute or relative).
# DEV_PLUGIN_PATHS=./plugins/gallery/dist,./plugins/manga/dist

# Comma-separated plugin names for `pnpm dev`.
# DEV_PLUGINS=gallery,manga

# Logging level
LOG_LEVEL=info

# Session cookie settings
SESSION_COOKIE_NAME=app_session
SESSION_TTL_SECONDS=2592000
SESSION_SECURE_COOKIE=false

# Force HTTPS redirects / Secure cookies when behind a TLS-terminating proxy
FORCE_HTTPS=false

# Disable loading dev plugins (recommended for public-facing deployments)
DISABLE_DEV_PLUGINS=false

# Upload/extraction limits (bytes)
MAX_UPLOAD_BYTES=17179869184
MAX_ARCHIVE_EXTRACTED_BYTES=68719476736

# Optional ffmpeg/ffprobe binary overrides
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# One-shot setup ---------------------------------------------------------------

# Set during `app-server-setup` to restore a DB snapshot before writing password.
# RESTORE_FROM=app-1.sqlite

# Admin password source (use file in production; plain env is convenient for dev).
# ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_FILE=/run/secrets/admin_password
