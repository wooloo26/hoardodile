{
	"name": "@hoardodile/server",
	"version": "0.0.0",
	"private": true,
	"license": "GPL-3.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./router": {
			"types": "./src/infra/trpc/router.ts",
			"default": "./dist/index.js"
		}
	},
	"bin": {
		"app-server": "./dist/main.js",
		"app-server-setup": "./dist/setup-main.js"
	},
	"scripts": {
		"dev": "vite-node --watch src/main.ts",
		"start": "node --enable-source-maps dist/main.js",
		"setup": "node dist/setup-main.js",
		"setup:dev": "vite-node src/setup-main.ts",
		"build": "vite build",
		"lint": "tsc --noEmit",
		"test": "vitest run",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push"
	},
	"devDependencies": {
		"@ffmpeg-installer/ffmpeg": "^1.1.0",
		"@ffprobe-installer/ffprobe": "^2.1.2",
		"@floating-ui/dom": "^1.8.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "catalog:",
		"@types/yauzl": "^3.4.0",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-node": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"@fastify/cookie": "^11.1.2",
		"@fastify/cors": "^11.3.0",
		"@fastify/multipart": "^10.1.0",
		"@fastify/rate-limit": "^11.1.0",
		"@fastify/sse": "^0.5.0",
		"@fastify/static": "^10.1.0",
		"@hoardodile/consts": "workspace:*",
		"@hoardodile/plugin-sdk-server": "workspace:*",
		"@hoardodile/plugin-sdk-types": "workspace:*",
		"@hoardodile/schemas": "workspace:*",
		"@hoardodile/shared": "workspace:*",
		"@hoardodile/ui": "workspace:*",
		"@node-rs/argon2": "^2.0.2",
		"@trpc/client": "^11.18.0",
		"@trpc/server": "^11.18.0",
		"@types/yazl": "^3.3.1",
		"better-sqlite3": "^13.0.1",
		"drizzle-orm": "^0.45.2",
		"es-toolkit": "catalog:",
		"eventemitter3": "^5.0.4",
		"fastify": "^5.10.0",
		"fastify-plugin": "^6.0.0",
		"get-port": "^7.2.0",
		"iron-session": "^8.0.4",
		"pino": "^10.3.1",
		"pino-roll": "^4.0.0",
		"sharp": "^0.35.3",
		"yauzl": "^3.4.0",
		"yazl": "^3.3.1",
		"zod": "catalog:"
	}
}
